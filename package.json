{
  "name": "finance-clarity-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "services/*",
    "apps/*"
  ],
  "scripts": {
    "mobile": "cd apps/mobile && npx expo start --tunnel --clear",
    "mobile:local": "cd apps/mobile && npx expo start --clear",
    "api:dev": "npm --workspace @finance-clarity/api run dev",
    "api:typecheck": "npm --workspace @finance-clarity/api run typecheck"
  }
}
